% ============================================================
% references.bib  —  Related Works for Stale-State Dispatcher
% Experiment: can LLMs zero-shot synthesize age-aware load-
% balancing strategies that beat Power-of-Two-Choices (Po2C)
% when per-worker heartbeat ages are provided as input?
% ============================================================


% ============================================================
% SECTION 1: Power of Two Choices / Supermarket Model
% ============================================================

% THE baseline algorithm this project attempts to beat.  Po2C
% (sample 2 workers, route to shorter) reduces expected queue
% length from O(log n / log log n) to O(log log n).  Directly
% cited as the "Po2C (stale)" baseline in the simulation.
@article{mitzenmacher2001power,
  author  = {Mitzenmacher, Michael},
  title   = {The Power of Two Choices in Randomized Load Balancing},
  journal = {IEEE Transactions on Parallel and Distributed Systems},
  volume  = {12},
  number  = {10},
  pages   = {1094--1104},
  year    = {2001},
  doi     = {10.1109/71.963420}
}

% Independent Russian discovery of the supermarket model via
% McKean–Vlasov mean-field ODEs; co-originator of the Po2C
% result that underpins all JSQ-d theory used here.
@article{vvedenskaya1996queueing,
  author  = {Vvedenskaya, N. D. and Dobrushin, R. L. and Karpelevich, F. I.},
  title   = {Queueing System with Selection of the Shortest of Two Queues:
             An Asymptotic Approach},
  journal = {Problems of Information Transmission},
  volume  = {32},
  number  = {1},
  pages   = {20--34},
  year    = {1996}
}

% Comprehensive survey of the balls-into-bins framing, d-choices
% generalization, and applications.  Essential background for
% understanding why d=2 yields exponential gains and why adding
% age-awareness could push further.
@incollection{mitzenmacher2001survey,
  author    = {Mitzenmacher, Michael and Richa, Andrea W. and Sitaraman, Ramesh},
  title     = {The Power of Two Random Choices: A Survey of Techniques and Results},
  booktitle = {Handbook of Randomized Computing},
  volume    = {1},
  pages     = {255--312},
  publisher = {Kluwer Academic Publishers},
  year      = {2001}
}

% Proves the key combinatorial result: placing each ball in the
% lighter of d>=2 bins reduces max load from Theta(log n/log log n)
% to Theta(log log n / log d).  Theoretical foundation for Po2C
% guarantees that any improved strategy must surpass.
@article{azar1999balanced,
  author  = {Azar, Yossi and Broder, Andrei Z. and Karlin, Anna R. and Upfal, Eli},
  title   = {Balanced Allocations},
  journal = {SIAM Journal on Computing},
  volume  = {29},
  number  = {1},
  pages   = {180--200},
  year    = {1999},
  doi     = {10.1137/S0097539795288490}
}

% Extends Po2C to distributed stream processing with Partial Key
% Grouping; shows practical engineering challenges (skew, partial
% state) that motivate studying alternatives like age-aware
% strategies in realistic settings.
@inproceedings{nasir2015power,
  author    = {Nasir, Muhammad Anis Uddin and Morales, Gianmarco De Francisci
               and Garcia-Soriano, David and Kourtellis, Nicolas and Serafini, Marco},
  title     = {The Power of Both Choices: Practical Load Balancing for
               Distributed Stream Processing Engines},
  booktitle = {Proceedings of the IEEE International Conference on Data
               Engineering (ICDE)},
  year      = {2015},
  pages     = {137--148}
}


